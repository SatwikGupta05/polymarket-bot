# Trading mode
# Keep this false for demos, hackathons, and paper trading.
LIVE_TRADING_ENABLED=false

# Polymarket live trading credentials
# Required only for real-money trading on Polymarket.
POLYGON_PRIVATE_KEY=your_polygon_private_key_here
POLYGON_PUBLIC_KEY=your_polygon_public_key_here

# Free-tier AI providers
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: multiple Gemini keys for automatic rotation
GEMINI_API_KEYS=

# Paid AI providers
XAI_API_KEY=your_xai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional: multiple OpenRouter keys for automatic rotation
OPENROUTER_API_KEYS=
OPENAI_API_KEY=your_openai_api_key_here

# Logging
LOG_LEVEL=INFO
ENABLE_FILE_LOGGING=true
ENABLE_CONSOLE_LOGGING=true

# Database
DATABASE_URL=sqlite:///trading_system.db

# Performance monitoring
ENABLE_PERFORMANCE_MONITORING=true
PERFORMANCE_LOG_INTERVAL_MINUTES=15
